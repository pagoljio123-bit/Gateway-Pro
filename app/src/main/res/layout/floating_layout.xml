<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start">

    <View
        android:id="@+id/stealth_bar"
        android:layout_width="5dp"
        android:layout_height="50dp"
        android:background="#11FFFFFF" 
        android:elevation="1dp" />

    <LinearLayout
        android:id="@+id/menu_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#05000000" 
        android:padding="8dp"
        android:visibility="gone">
        <Button android:id="@+id/btn_lens_on" android:layout_width="130dp" android:layout_height="38dp" android:text="Start Lens" android:textSize="10sp" android:backgroundTint="#6600ffcc" android:textColor="#000" />
        <Button android:id="@+id/btn_lens_off" android:layout_width="130dp" android:layout_height="38dp" android:text="Stop Lens" android:textSize="10sp" android:backgroundTint="#66555555" android:textColor="#fff" android:visibility="gone" />
        <Button android:id="@+id/btn_keyboard" android:layout_width="130dp" android:layout_height="38dp" android:layout_marginTop="4dp" android:text="Keyboard" android:textSize="10sp" android:backgroundTint="#66ffcc00" android:textColor="#000" />
        <Button android:id="@+id/btn_full_hide" android:layout_width="130dp" android:layout_height="38dp" android:layout_marginTop="4dp" android:text="Go Invisible" android:textSize="10sp" android:backgroundTint="#66ffffff" android:textColor="#000" />
        <Button android:id="@+id/btn_exit" android:layout_width="130dp" android:layout_height="38dp" android:layout_marginTop="4dp" android:text="Exit System" android:textSize="10sp" android:backgroundTint="#66ff3366" android:textColor="#fff" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/keyboard_layout"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#15000000"
        android:padding="12dp"
        android:visibility="gone">
        <Button android:id="@+id/btn_close_kb" android:layout_width="wrap_content" android:layout_height="32dp" android:text="Close" android:textSize="9sp" android:backgroundTint="#88ff3366" />
        <EditText android:id="@+id/magic_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Type..." android:textColor="#00ffcc" android:background="#22ffffff" android:padding="10dp" />
    </LinearLayout>
</LinearLayout>
