<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#00000000">

    <View
        android:id="@+id/dot_icon"
        android:layout_width="10dp"
        android:layout_height="60dp"
        android:background="#8800ffcc"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/menu_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#33000000"
        android:padding="10dp"
        android:visibility="gone">
        <Button android:id="@+id/btn_glass_scanner" android:layout_width="120dp" android:layout_height="40dp" android:text="Scanner" android:textSize="10sp" android:backgroundTint="#4400ffcc" />
        <Button android:id="@+id/btn_auto_keyboard" android:layout_width="120dp" android:layout_height="40dp" android:layout_marginTop="5dp" android:text="Keyboard" android:textSize="10sp" android:backgroundTint="#44ffcc00" />
        <Button android:id="@+id/btn_hide" android:layout_width="120dp" android:layout_height="40dp" android:layout_marginTop="5dp" android:text="Hide" android:textSize="10sp" android:backgroundTint="#44ffffff" />
        <Button android:id="@+id/btn_exit" android:layout_width="120dp" android:layout_height="40dp" android:layout_marginTop="5dp" android:text="Close" android:textSize="10sp" android:backgroundTint="#44ff3366" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/glass_scanner_layout"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:background="#11FFFFFF"
        android:padding="2dp"
        android:visibility="gone">
        
        <View android:id="@+id/drag_handle" android:layout_width="match_parent" android:layout_height="20dp" android:background="#4400ffcc" />
        
        <TextView android:id="@+id/glass_decoded_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true" android:background="#66000000" android:padding="5dp" android:text="Scanning..." android:textColor="#00ffcc" android:textSize="14sp" />
        
        <Button android:id="@+id/btn_back_glass" android:layout_width="50dp" android:layout_height="30dp" android:layout_below="@id/drag_handle" android:text="Back" android:textSize="8sp" android:backgroundTint="#66000000" />
        <View android:id="@+id/resize_handle" android:layout_width="30dp" android:layout_height="30dp" android:layout_alignParentEnd="true" android:layout_alignParentBottom="true" android:background="#44ffffff" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/keyboard_layout"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#44000000"
        android:padding="10dp"
        android:visibility="gone">
        <Button android:id="@+id/btn_back_kb" android:layout_width="wrap_content" android:layout_height="30dp" android:text="Back" android:textSize="8sp" android:backgroundTint="#66000000" />
        <EditText android:id="@+id/magic_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Type here..." android:textColor="#fff" android:background="#22FFFFFF" android:padding="8dp" android:layout_marginTop="5dp" />
    </LinearLayout>
</FrameLayout>
