<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/dot_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="top|start"
        android:background="@android:drawable/ic_dialog_info"
        android:backgroundTint="#00ffcc"
        android:elevation="10dp" />

    <LinearLayout
        android:id="@+id/menu_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#E6000000"
        android:orientation="vertical"
        android:padding="15dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_glass_scanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Glass Scanner"
            android:backgroundTint="#00ffcc"
            android:textColor="#000" />

        <Button
            android:id="@+id/btn_auto_keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Auto Keyboard"
            android:backgroundTint="#ffcc00"
            android:textColor="#000" />

        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Exit System"
            android:backgroundTint="#ff3366"
            android:textColor="#fff" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/glass_scanner_layout"
        android:layout_width="300dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:background="#4400ffcc"
        android:visibility="gone">

        <TextView
            android:id="@+id/glass_decoded_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#CC000000"
            android:padding="10dp"
            android:text="Waiting for code..."
            android:textColor="#00ffcc"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_close_glass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:text="X"
            android:backgroundTint="#ff3366"
            android:textColor="#fff" />
            
        <Button
            android:id="@+id/btn_resize_glass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:text="Size"
            android:backgroundTint="#555"
            android:textColor="#fff" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/keyboard_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E6000000"
        android:orientation="vertical"
        android:padding="15dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_close_keyboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Close Keyboard"
            android:backgroundTint="#ff3366"
            android:textColor="#fff" />

        <EditText
            android:id="@+id/magic_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#333"
            android:hint="Type here (বাংলা/English)..."
            android:padding="15dp"
            android:textColor="#fff"
            android:textColorHint="#888" />
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Your text is automatically converted and typed into WhatsApp."
            android:textColor="#ffcc00"
            android:textSize="12sp" />
    </LinearLayout>

</FrameLayout>
